
# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Optional in local development when the Vite frontend and socket server run on separate ports.
VITE_SOCKET_SERVER_URL="http://127.0.0.1:3001"

# Neon Postgres connection string. Required on Render for persisted player/match data.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"

# Set to "false" if you want to manage db/schema.sql manually instead of bootstrapping on server start.
DB_AUTO_MIGRATE="true"

# Solana wager payments. Use a dedicated low-balance hot wallet; never use treasury here.
SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
VITE_SOLANA_RPC_URL="https://api.mainnet-beta.solana.com"
UNC_TOKEN_MINT="ACtfUWtgvaXrQGNMiohTusi5jcx5RJf5zwu9aAxkpump"
VITE_UNC_TOKEN_MINT="ACtfUWtgvaXrQGNMiohTusi5jcx5RJf5zwu9aAxkpump"
UNC_TOKEN_DECIMALS="6"
VITE_UNC_TOKEN_DECIMALS="6"
HOT_WALLET_ADDRESS="HOT_WALLET_PUBLIC_KEY"
HOT_WALLET_SECRET_KEY="[1,2,3,...]"
TREASURY_WALLET_ADDRESS="COLD_TREASURY_PUBLIC_KEY"
